# ============================================
# CONFIGURACIÓN DE SUPABASE - OPTIGASTO
# ============================================

# Credenciales de Supabase (obtener de https://app.supabase.com → Settings → API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OAuth - Google Sign-In (configurar en https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_SECRET=your-google-secret

# OAuth - Apple Sign-In (configurar en https://developer.apple.com)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_SECRET=your-apple-secret

# Google Maps API Key (obtener de https://console.cloud.google.com/google/maps-apis)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Configuración de desarrollo local (Supabase CLI)
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_ANON_KEY=your-local-anon-key-here

# ============================================
# VERCEL DEPLOY — variables requeridas en el dashboard
# ============================================
# Las siguientes 3 variables son obligatorias en Vercel > Settings > Environment Variables:
#   SUPABASE_URL         (mismo valor que arriba)
#   SUPABASE_ANON_KEY    (mismo valor que arriba)
#   GOOGLE_MAPS_API_KEY  (mismo valor que arriba)

# ============================================
# FIREBASE WEB CONFIG (opcional — push en web)
# Valores PÚBLICOS del Web App en Firebase Console
# > Project Settings > Your Apps > Web App
# ============================================
# FIREBASE_WEB_API_KEY=your-firebase-web-api-key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# FIREBASE_APP_ID=your-app-id

# Made with Bob

